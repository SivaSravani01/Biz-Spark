class LoginScreen extends StatefulWidget {
  const LoginScreen({super.key});

  @override
  State<LoginScreen> createState() => _LoginScreenState();
}

class _LoginScreenState extends State<LoginScreen> {
  bool isStudent = true;
  final emailController = TextEditingController();
  final passwordController = TextEditingController();
  String? emailError;

  void login() {
    if (!emailController.text.trim().endsWith('@gmail.com')) {
      setState(() {
        emailError = 'Enter a Gmail address ending with @gmail.com';
      });
      return;
    }

    Navigator.pushReplacement(
      context,
      MaterialPageRoute(
        builder: (_) =>
            isStudent ? const StudentHomeScreen() : const InvestorHomeScreen(),
      ),
    );
  }

  @override
  void dispose() {
    emailController.dispose();
    passwordController.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      body: SafeArea(
        child: ScreenCard(
          child: Column(
            children: [
              const Text(
                'Welcome Back',
                style: TextStyle(
                  color: Colors.white,
                  fontSize: 29,
                  fontWeight: FontWeight.bold,
                ),
              ),
              const SizedBox(height: 8),
              const Text(
                "Let's get you started.",
                style: TextStyle(color: lightText),
              ),
              const SizedBox(height: 28),
              Row(
                children: [
                  Expanded(
                    child: ChoiceChip(
                      label: const Center(child: Text('Student')),
                      selected: isStudent,
                      selectedColor: orange,
                      backgroundColor: blue,
                      labelStyle: const TextStyle(color: Colors.white),
                      onSelected: (_) => setState(() => isStudent = true),
                    ),
                  ),
                  const SizedBox(width: 10),
                  Expanded(
                    child: ChoiceChip(
                      label: const Center(child: Text('Investor')),
                      selected: !isStudent,
                      selectedColor: orange,
                      backgroundColor: blue,
                      labelStyle: const TextStyle(color: Colors.white),
                      onSelected: (_) => setState(() => isStudent = false),
                    ),
                  ),
                ],
              ),
              const SizedBox(height: 25),
              AppField(
                label: 'Gmail',
                hint: 'example@gmail.com',
                controller: emailController,
                errorText: emailError,
              ),
              AppField(
                label: 'Password',
                password: true,
                controller: passwordController,
              ),
              AppButton(text: 'Log In', onTap: login),
              const SizedBox(height: 22),
              Row(
                mainAxisAlignment: MainAxisAlignment.center,
                children: [
                  const Text(
                    "Don't have an account? ",
                    style: TextStyle(color: lightText),
                  ),
                  GestureDetector(
                    onTap: () {
                      Navigator.push(
                        context,
                        MaterialPageRoute(builder: (_) => const SignUpScreen()),
                      );
                    },
                    child: const Text(
                      'Sign Up',
                      style: TextStyle(
                        color: orange,
                        fontWeight: FontWeight.bold,
                      ),
                    ),
                  ),
                ],
              ),
            ],
          ),
        ),
      ),
    );
  }
}

